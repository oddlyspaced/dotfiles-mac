# Machine-local secrets sourced by config.fish.
#
#   cp secrets.fish.example secrets.fish
#   $EDITOR secrets.fish
#
# `secrets.fish` is gitignored — never commit real credentials.

# Fastlane / iOS code signing (Swish)
set -x FASTLANE_USER 'you@example.com'
set -x MATCH_PASSWORD 'change-me'
set -x FASTLANE_APPLE_APPLICATION_SPECIFIC_PASSWORD 'xxxx-xxxx-xxxx-xxxx'
